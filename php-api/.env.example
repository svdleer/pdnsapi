# PowerDNS Admin API Configuration
# Copy this file to .env and fill in your actual values
# This file contains sensitive credentials - never commit .env to git!

# PowerDNS Admin API Key (base64 encoded admin:password)
PDNS_API_KEY=your_base64_encoded_admin_password

# PowerDNS Server API Key
PDNS_SERVER_KEY=your_powerdns_server_api_key

# PowerDNS Admin Base URL
PDNS_BASE_URL=https://your-powerdns-admin.domain.com/api/v1

# PowerDNS Admin Login Credentials
PDNS_ADMIN_USER=admin
PDNS_ADMIN_PASSWORD=your_admin_password

# PowerDNS Admin Database Configuration
PDNS_ADMIN_DB_HOST=your_database_host
PDNS_ADMIN_DB_PORT=3306
PDNS_ADMIN_DB_NAME=pda
PDNS_ADMIN_DB_USER=your_db_user
PDNS_ADMIN_DB_PASS=your_db_password

# API Database Configuration (for business logic)
API_DB_HOST=your_database_host
API_DB_PORT=3306
API_DB_NAME=pdns_api_db
API_DB_USER=your_db_user
API_DB_PASS=your_db_password
API_DB_CHARSET=utf8mb4

# Avant API key (if applicable)
AVANT_API_KEY=your_avant_api_key_if_needed
